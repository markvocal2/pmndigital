# /opt/docker/main-pmndigital/.env on the VPS — copy this file, fill values, chmod 600.
# NEVER commit the real .env. NEVER commit secrets.

# Postgres
POSTGRES_USER=pmndigital
POSTGRES_PASSWORD=
POSTGRES_DB=pmndigital

# Connection string for backend + frontend
DATABASE_URL=postgresql://pmndigital:<password>@db:5432/pmndigital

# Frontend (Next.js / NextAuth)
NEXTAUTH_URL=https://pmndigital.co
NEXTAUTH_SECRET=

# Backend
JWT_SECRET=

# Image tags (latest = follow main; pin to sha-<commit> for rollback)
BACKEND_TAG=latest
FRONTEND_TAG=latest
