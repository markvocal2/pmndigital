generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum LeadType {
  REGISTER
  CONTACT
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String

  role UserRole @default(USER)

  // Profile
  firstName   String?
  lastName    String?
  displayName String?
  name        String? // legacy field, deprecate later
  avatarUrl   String? // /uploads/avatars/<id>-<hash>.<ext>

  // 2FA (TOTP)
  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String? // base32 secret, AES-256-GCM encrypted at rest
  twoFactorBackupCodes Json? // array of {hash: bcrypt(code), used: boolean}

  // ERP linkage
  erpCustomerId Int?
  erpSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  auditLogs AuthAuditLog[]
  articles  Article[]

  @@index([erpCustomerId])
}

// Audit log for security-sensitive actions
model AuthAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  event     String // login_success, login_failed, password_changed, 2fa_enabled, 2fa_disabled, 2fa_failed, 2fa_succeeded, profile_updated, avatar_updated
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

// Sitewide settings (singleton row, key="default")
model SiteSetting {
  id               Int      @id @default(autoincrement())
  key              String   @unique @default("default")
  siteName         String   @default("PMN Digital")
  siteNameEn       String?
  tagline          String?
  logoLightUrl     String?
  logoDarkUrl      String?
  logoHeight       Int      @default(32)
  faviconUrl       String?
  ogDefaultUrl     String?
  timezone         String   @default("Asia/Bangkok")
  defaultLocale    String   @default("th")
  themeDefault     String   @default("dark")
  contactEmail     String?
  contactPhone     String?
  contactAddress   String?
  geoLat           Float?
  geoLng           Float?
  mapUrl           String?
  socials          Json?
  defaultMetaTitle String?
  defaultMetaDesc  String?
  defaultKeywords  String?
  gaId             String?
  gtmId            String?
  maintenanceMode  Boolean  @default(false)
  extra            Json?
  updatedAt        DateTime @updatedAt @default(now())
}

// Homepage content (singleton row, key="home"); `data` holds the full section tree.
model HomeContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique @default("home")
  data      Json
  seo       Json?
  updatedAt DateTime @updatedAt @default(now())
}

model ArticleCategory {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String
  nameEn    String?
  createdAt DateTime  @default(now())
  articles  Article[]
}

model Article {
  id            Int           @id @default(autoincrement())
  slug          String        @unique
  title         String
  excerpt       String?
  bodyMarkdown  String        @default("")
  coverImageUrl String?
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      Int?
  author        User?         @relation(fields: [authorId], references: [id])
  categoryId    Int?
  category      ArticleCategory? @relation(fields: [categoryId], references: [id])
  tags          String[]
  readingMins   Int           @default(1)

  // SEO
  metaTitle    String?
  metaDesc     String?
  canonicalUrl String?
  ogImageUrl   String?
  noindex      Boolean @default(false)

  // GEO (Generative Engine Optimization)
  keyphrase  String?
  faq        Json?      // [{q, a}]
  takeaways  String[]
  schemaType String     @default("Article")

  viewCount Int       @default(0)
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@index([status, publishedAt])
  @@index([categoryId])
}

model Comment {
  id          Int           @id @default(autoincrement())
  articleId   Int
  article     Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String?
  body        String
  status      CommentStatus @default(PENDING)
  ip          String?
  userAgent   String?
  createdAt   DateTime      @default(now())

  @@index([articleId, status])
  @@index([status, createdAt])
}

// Homepage form submissions (register / contact)
model Lead {
  id        Int        @id @default(autoincrement())
  type      LeadType
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message    String?
  status     LeadStatus @default(NEW)
  source     String?
  couponCode String?
  couponId   Int?
  ip         String?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([type, createdAt])
  @@index([status, createdAt])
}

// Uploaded media metadata — files live on PMN Drive (drive.pmndigital.co), served via cdn.pmndigital.co
model Media {
  id        Int      @id @default(autoincrement())
  driveName String
  url       String
  origName  String?
  mime      String?
  size      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum DiscountType {
  PERCENT
  FIXED
  BUNDLE
  FREE
  OTHER
}

// Promotions / campaigns shown on the homepage ("โปรเด็ดประจำเดือน") and /promotions
model Promotion {
  id             Int          @id @default(autoincrement())
  title          String
  subtitle       String?
  description    String?
  badge          String?
  discountType   DiscountType @default(PERCENT)
  discountValue  Float?
  originalPrice  Float?
  finalPrice     Float?
  priceUnit      String?
  imageUrl       String?
  ctaText        String?
  ctaUrl         String?
  couponCode     String?
  terms          String?
  highlightColor String?
  startsAt       DateTime?
  endsAt         DateTime?
  active         Boolean      @default(true)
  featured       Boolean      @default(false)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([active, featured])
  @@index([startsAt, endsAt])
}

// Limited-quantity coupon codes, redeemed when a lead is submitted
model Coupon {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  description    String?
  discountType   DiscountType @default(PERCENT)
  discountValue  Float        @default(0)
  maxRedemptions Int?
  redeemedCount  Int          @default(0)
  perEmailLimit  Int?
  minPurchase    Float?
  promotionId    Int?
  startsAt       DateTime?
  endsAt         DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([active])
}

model CouponRedemption {
  id        Int      @id @default(autoincrement())
  couponId  Int
  code      String
  leadId    Int?
  email     String?
  createdAt DateTime @default(now())

  @@index([couponId, createdAt])
}

enum IntegrationProvider {
  ANTHROPIC
  GEMINI
  OPENAI
}

enum IntegrationMode {
  API_KEY
  OAUTH
}

// AI provider credentials (encrypted) configured via /admin/integrations — not .env
model Integration {
  id           Int                 @id @default(autoincrement())
  provider     IntegrationProvider @unique
  mode         IntegrationMode     @default(API_KEY)
  enabled      Boolean             @default(false)
  secretEnc    String?
  meta         Json?
  status       String?
  statusMsg    String?
  lastTestedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

// --- MCP OAuth 2.1 authorization server (claude.ai connector) ---
model OAuthClient {
  id           Int      @id @default(autoincrement())
  clientId     String   @unique
  clientSecret String?
  clientName   String?
  redirectUris String[]
  scope        String?
  metadata     Json?
  createdAt    DateTime @default(now())
}

model OAuthCode {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  clientId      String
  userId        Int
  codeChallenge String
  redirectUri   String
  resource      String?
  scope         String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

model OAuthToken {
  id           Int      @id @default(autoincrement())
  accessToken  String   @unique
  refreshToken String?  @unique
  clientId     String
  userId       Int
  scope        String?
  resource     String?
  expiresAt    DateTime
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// Autonomous scheduled jobs (cron) — toggleable from /admin/automation
model AutomationJob {
  id          Int       @id @default(autoincrement())
  jobKey      String    @unique
  enabled     Boolean   @default(false)
  config      Json?
  lastRunAt   DateTime?
  lastStatus  String?
  lastMessage String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
